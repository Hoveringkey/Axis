# Copy this file to .env and fill in real values.
# Never commit .env — only commit .env.example.

# Local development placeholder. Replace it outside local dev.
SECRET_KEY=dev-local-axis-secret-key

# True for local development only. Must be False in production.
DEBUG=True

# Supabase local default PostgreSQL URL.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Comma-separated list of allowed hostnames.
# Leave empty for local dev (Django allows localhost by default when DEBUG=True).
# Production example: ALLOWED_HOSTS=avanplastic.example.com,www.avanplastic.example.com
ALLOWED_HOSTS=
